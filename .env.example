# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# App URLs
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Auth
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_ENABLED="true"
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_ENABLED="true"
TURNSTILE_SECRET_KEY=""

# Email / Resend
RESEND_API_KEY=""
EMAIL_FROM="no-reply@example.com"

# Supabase (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Server-only: Settings → API → service_role (never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=""

# Storage bucket name (must match a bucket in Storage; same as legacy S3_BUCKET)
S3_BUCKET="taseron"
# Optional alias:
# SUPABASE_STORAGE_BUCKET="taseron"
